    "radon": {
      "enabled": true,
      "config": {
        "threshold": "C"
      }
    },
    "pylint": {
      "enabled": true,
      "channel": "pylint",
      "config": {
        "disable": [
          "C0114",
          "C0115",
          "C0116"
        ]
      }
    },
    "pep8": {
      "enabled": true,
      "config": {
        "max_line_length": 120
      }
    },
    "duplication": {
      "enabled": true,
      "config": {
        "languages": {
          "python": {
            "mass_threshold": 40,
            "count_threshold": 2
          }
        }
      }
    },
    "fixme": {
      "enabled": true,
      "config": {
        "strings": [
          "FIXME",
          "TODO",
          "HACK",
          "XXX",
          "BUG",
          "SECURITY"
        ]
      }
    }
  },
  "exclude_patterns": [
    ".git/",
    ".tox/",
    ".eggs/",
    "*.egg-info/",
    "build/",
    "dist/",
    "venv/",
    ".venv/",
    "__pycache__/",
    "*.pyc",
    "docs/",
    "tests/fixtures/",
    "node_modules/",
    ".mypy_cache/",
    ".pytest_cache/",
    "htmlcov/",
    "*.min.js"
  ],
  "custom_security_rules": {
    "_comment": "Custom rules mapping to NIST 800-171 and OWASP Secure by Design",
    "nist_800_171_mapping": {
      "3.1.1": {
        "name": "Access Control - Authorized Access",
        "description": "Limit system access to authorized users",
        "checks": ["B102", "B307", "B602", "B603", "B604", "B605", "B606", "B607", "B608", "B609"]
      },
      "3.1.2": {
        "name": "Access Control - Transaction Types",
        "description": "Limit system access to types of transactions and functions",
        "checks": ["B103", "B108"]
      },
      "3.4.1": {
        "name": "Configuration Management - Baseline",
        "description": "Establish and maintain baseline configurations",
        "checks": ["B108", "B201"]
      },
      "3.4.2": {
        "name": "Configuration Management - Security Settings",
        "description": "Establish and enforce security configuration settings",
        "checks": ["B103", "B104"]
      },
      "3.5.10": {
        "name": "Identification and Authentication - Password Storage",
        "description": "Store and transmit only cryptographically-protected passwords",
        "checks": ["B105", "B106", "B107"]
      },
      "3.13.1": {
        "name": "System and Communications - Boundary Protection",
        "description": "Monitor, control, and protect communications at boundaries",
        "checks": ["B104", "B310"]
      },
      "3.13.8": {
        "name": "System and Communications - Cryptographic Protection",
        "description": "Implement cryptographic mechanisms to prevent unauthorized disclosure",
        "checks": ["B301", "B302", "B306", "B312", "B321", "B323", "B401", "B402", "B501", "B502", "B503", "B504", "B507", "B508", "B509"]
      },
      "3.13.11": {
        "name": "System and Communications - FIPS Cryptography",
        "description": "Employ FIPS-validated cryptography",
        "checks": ["B303", "B304", "B305", "B311", "B324", "B413", "B415", "B505"]
      },
      "3.14.1": {
        "name": "System and Information Integrity - Flaw Remediation",
        "description": "Identify, report, and correct system flaws",
        "checks": ["B201"]
      }
